const STORAGE_KEY = "calculadoraCarbonoTpfV4";
const RESULTS_TAB_KEY = "__results__";
const MAX_VISIBLE_OPTIONS = 45;
const SEARCH_DEBOUNCE_MS = 120;

const SCENARIO_LABELS = {
  min: "mínimo",
  med: "médio",
  max: "máximo",
};

const SCENARIO_FIELD = {
  min: "emissao_composicao_min",
  med: "emissao_composicao_med",
  max: "emissao_composicao_max",
};

const BENCHMARKS = [
  {
    id: "sinduscon",
    title: "SindusCon/SP (2024)",
    min: 0.10,
    max: 0.52,
    label: "0,10 a 0,52 tCO₂e/m²",
    note: "Faixa média reportada no levantamento informado para comparação rápida do desempenho do projeto.",
  },
  {
    id: "academico",
    title: "Caldas et al. (2017), Belizário (2022) e Melo et al. (2023)",
    min: 0.27,
    max: 0.39,
    label: "0,27 a 0,39 tCO₂e/m²",
    note: "Faixa média de estudos acadêmicos informados para edificações e análises comparáveis.",
  },
];

const defaultState = {
  scenario: "med",
  scenarioName: "Simulação 1",
  builtArea: 0,
  showIncomplete: true,
  selected: {},
  quantities: {},
  conversionRates: {},
  history: [],
  counter: 1,
  activeCategory: null,
};

let state = loadState();
let categories = [];
let itemsByCategory = {};
let searchByCategory = {};
let activePanelScrollTop = 0;

const el = {
  scenarioName: document.getElementById("scenarioName"),
  builtArea: document.getElementById("builtArea"),
  showIncomplete: document.getElementById("showIncomplete"),
  clearQuantities: document.getElementById("clearQuantities"),
  clearHistory: document.getElementById("clearHistory"),
  saveSimulation: document.getElementById("saveSimulation"),
  categoryTabs: document.getElementById("categoryTabs"),
  activeCategoryPanel: document.getElementById("activeCategoryPanel"),
  scenarioLabel: document.getElementById("scenarioLabel"),
  totalEmission: document.getElementById("totalEmission"),
  areaRate: document.getElementById("areaRate"),
  majorCategory: document.getElementById("majorCategory"),
  majorCategoryValue: document.getElementById("majorCategoryValue"),
  reductionIndicator: document.getElementById("reductionIndicator"),
  reductionHelper: document.getElementById("reductionHelper"),
  missingDataAlert: document.getElementById("missingDataAlert"),
  conversionAlert: document.getElementById("conversionAlert"),
  historyEmpty: document.getElementById("historyEmpty"),
  historyContent: document.getElementById("historyContent"),
  historyChart: document.getElementById("historyChart"),
  historyHighlights: document.getElementById("historyHighlights"),
  historyRows: document.getElementById("historyRows"),
};

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return structuredClone(defaultState);
    const parsed = JSON.parse(raw);
    return {
      ...structuredClone(defaultState),
      ...parsed,
      selected: parsed.selected || {},
      quantities: parsed.quantities || {},
      conversionRates: parsed.conversionRates || {},
      history: parsed.history || [],
    };
  } catch (err) {
    console.warn("Não foi possível carregar o estado salvo.", err);
    return structuredClone(defaultState);
  }
}

function saveState() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
}

function escapeHtml(value) {
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function normalizeText(value) {
  return String(value ?? "")
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toUpperCase();
}

function formatNumber(value, decimals = 1) {
  if (value === null || value === undefined || Number.isNaN(Number(value))) return "-";
  return Number(value).toLocaleString("pt-BR", {
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals,
  });
}

function formatInputValue(value) {
  const number = Number(value);
  if (!Number.isFinite(number) || number === 0) return "";
  return String(number).replace(".", ",");
}

function formatKg(value, decimals = 1) {
  return `${formatNumber(value, decimals)} kgCO₂e`;
}

function formatTon(value, decimals = 3) {
  return `${formatNumber(value, decimals)} tCO₂e/m²`;
}

function readNumberInput(input) {
  const value = Number.parseFloat(String(input.value).replace(",", "."));
  return Number.isFinite(value) ? value : 0;
}

function createId() {
  return globalThis.crypto?.randomUUID ? crypto.randomUUID() : String(Date.now());
}

function debounce(fn, wait = SEARCH_DEBOUNCE_MS) {
  let timeoutId;
  return (...args) => {
    window.clearTimeout(timeoutId);
    timeoutId = window.setTimeout(() => fn(...args), wait);
  };
}

function unitOf(item) {
  return String(item?.unidade || "").toUpperCase().trim();
}

function unitIsM2(item) {
  return unitOf(item) === "M2";
}

function getFactor(item) {
  if (!item) return 0;
  const field = SCENARIO_FIELD[state.scenario] || SCENARIO_FIELD.med;
  const value = Number(item[field]);
  return Number.isFinite(value) ? value : 0;
}

function findItem(categoryKey, code) {
  if (!code) return null;
  return (itemsByCategory[categoryKey] || []).find((item) => String(item.codigo_composicao) === String(code)) || null;
}

function getActiveCategory() {
  if (state.activeCategory === RESULTS_TAB_KEY) return null;
  return categories.find((cat) => cat.category_key === state.activeCategory) || categories[0] || null;
}

function getQuantityData(categoryKey, item) {
  const baseQuantity = Number(state.quantities[categoryKey] || 0);
  if (!item) {
    return { baseQuantity, conversionRate: 0, effectiveQuantity: 0, needsConversion: false, hasConversion: true };
  }

  const needsConversion = !unitIsM2(item);
  if (!needsConversion) {
    return { baseQuantity, conversionRate: 1, effectiveQuantity: baseQuantity, needsConversion, hasConversion: true };
  }

  const conversionRate = Number(state.conversionRates[categoryKey] || 0);
  const hasConversion = conversionRate > 0;
  return {
    baseQuantity,
    conversionRate,
    effectiveQuantity: hasConversion ? baseQuantity * conversionRate : 0,
    needsConversion,
    hasConversion,
  };
}

function getCategoryStatus(category) {
  const item = findItem(category.category_key, state.selected[category.category_key]);
  const qtyData = getQuantityData(category.category_key, item);
  const hasQuantity = qtyData.baseQuantity > 0;

  if (!item) return { text: "vazio", kind: "empty" };
  if (Number(item.is_complete) !== 1 && hasQuantity) return { text: "sem dados", kind: "warning" };
  if (qtyData.needsConversion && hasQuantity && !qtyData.hasConversion) return { text: "conversão", kind: "pending" };
  if (hasQuantity) return { text: "pronto", kind: "ready" };
  return { text: "escolhido", kind: "pending" };
}

async function fetchJson(url) {
  const response = await fetch(url);
  if (!response.ok) throw new Error(`Erro ${response.status} ao carregar ${url}`);
  return response.json();
}

async function loadAllItems() {
  const show = state.showIncomplete ? "1" : "0";
  const pairs = await Promise.all(
    categories.map(async (category) => {
      const data = await fetchJson(`/api/items/${encodeURIComponent(category.category_key)}?show_incomplete=${show}`);
      return [category.category_key, data];
    })
  );

  itemsByCategory = Object.fromEntries(pairs);
}

function cleanupInvalidSelections() {
  categories.forEach((category) => {
    const key = category.category_key;
    const selectedCode = state.selected[key];
    if (!selectedCode) return;
    if (!findItem(key, selectedCode)) delete state.selected[key];
  });
  saveState();
}

function bindGlobalEvents() {
  document.querySelectorAll(".scenario-btn").forEach((button) => {
    button.addEventListener("click", () => {
      state.scenario = button.dataset.scenario;
      saveState();
      setScenarioButtons();
      renderActiveCategory();
      updateAll();
    });
  });

  el.scenarioName.addEventListener("input", () => {
    state.scenarioName = el.scenarioName.value;
    saveState();
  });

  el.builtArea.addEventListener("input", () => {
    state.builtArea = readNumberInput(el.builtArea);
    saveState();
    updateAll();
  });

  el.showIncomplete.addEventListener("change", async () => {
    state.showIncomplete = el.showIncomplete.checked;
    saveState();
    el.activeCategoryPanel.innerHTML = `<div class="loading-card">Atualizando composições...</div>`;
    await loadAllItems();
    cleanupInvalidSelections();
    renderTabs();
    renderActiveCategory();
    updateAll();
  });

  el.clearQuantities.addEventListener("click", () => {
    state.quantities = {};
    state.conversionRates = {};
    saveState();
    renderTabs();
    renderActiveCategory();
    updateAll();
  });

  el.clearHistory.addEventListener("click", () => {
    state.history = [];
    saveState();
    updateAll();
  });

  el.saveSimulation.addEventListener("click", () => {
    const summary = calculateSummary();
    const fallbackName = `Simulação ${state.counter || 1}`;
    const name = (el.scenarioName.value || "").trim() || fallbackName;

    const entry = {
      id: createId(),
      nome: name,
      cenario: state.scenario,
      cenarioLabel: SCENARIO_LABELS[state.scenario],
      total: summary.total,
      builtArea: summary.builtArea,
      areaRate: summary.areaRate,
      areaRateTon: summary.areaRateTon,
      majorCategory: summary.majorCategory,
      majorValue: summary.majorValue,
      createdAt: new Date().toLocaleString("pt-BR"),
    };

    state.history = [...(state.history || []), entry].slice(-5);
    state.counter = (Number(state.counter) || 1) + 1;
    state.scenarioName = `Simulação ${state.counter}`;
    el.scenarioName.value = state.scenarioName;
    saveState();
    updateAll();
  });
}

function setScenarioButtons() {
  document.querySelectorAll(".scenario-btn").forEach((button) => {
    button.classList.toggle("active", button.dataset.scenario === state.scenario);
  });
  const label = SCENARIO_LABELS[state.scenario] || "médio";
  el.scenarioLabel.textContent = `Cenário ${label}`;
}

function renderTabs() {
  if (!categories.length) {
    el.categoryTabs.innerHTML = "";
    return;
  }

  const categoryButtons = categories.map((category, index) => {
    const status = getCategoryStatus(category);
    const isActive = category.category_key === state.activeCategory;
    return `
      <button class="tab-button ${isActive ? "active" : ""} ${status.kind}" type="button" data-category="${escapeHtml(category.category_key)}" title="${escapeHtml(category.label)}">
        <span class="tab-index">Categoria ${String(index + 1).padStart(2, "0")}</span>
        <span class="tab-label">${escapeHtml(category.label)}</span>
        <span class="tab-status">${escapeHtml(status.text)}</span>
      </button>
    `;
  }).join("");

  const summary = calculateSummary();
  const resultsStatus = summary.areaRateTon === null ? "informe área" : "indicadores";
  const resultsActive = state.activeCategory === RESULTS_TAB_KEY;
  const resultsButton = `
    <button class="tab-button results-tab ${resultsActive ? "active" : ""} ready" type="button" data-category="${RESULTS_TAB_KEY}" title="Resultados e indicadores">
      <span class="tab-index">Síntese</span>
      <span class="tab-label">Resultados</span>
      <span class="tab-status">${resultsStatus}</span>
    </button>
  `;

  el.categoryTabs.innerHTML = categoryButtons + resultsButton;

  el.categoryTabs.querySelectorAll(".tab-button").forEach((button) => {
    button.addEventListener("click", () => {
      activePanelScrollTop = window.scrollY;
      state.activeCategory = button.dataset.category;
      saveState();
      renderTabs();
      renderActiveCategory();
      window.scrollTo({ top: activePanelScrollTop, behavior: "instant" });
    });
  });
}

function bindConversionInput(conversionInput, categoryKey) {
  if (!conversionInput) return;
  conversionInput.addEventListener("input", () => {
    state.conversionRates[categoryKey] = readNumberInput(conversionInput);
    saveState();
    updateAll();
    updateActiveCategoryLightweight(categoryKey);
  });
}

function renderActiveCategory() {
  if (state.activeCategory === RESULTS_TAB_KEY) {
    renderResultsTab();
    return;
  }

  const category = getActiveCategory();
  if (!category) {
    el.activeCategoryPanel.innerHTML = `<div class="loading-card">Nenhuma categoria encontrada.</div>`;
    return;
  }

  const categoryKey = category.category_key;
  const item = findItem(categoryKey, state.selected[categoryKey]);
  const quantity = Number(state.quantities[categoryKey] || 0);
  const qtyData = getQuantityData(categoryKey, item);
  const status = getCategoryStatus(category);
  const selectedMarkup = item ? renderSelectedMarkup(item, qtyData) : renderNoSelectionMarkup();
  const conversionMarkup = item && qtyData.needsConversion ? renderConversionMarkup(item, qtyData) : "";
  const metricsMarkup = item ? renderMetricsMarkup(category, item, qtyData) : renderEmptyMetricsMarkup();
  const searchValue = searchByCategory[categoryKey] || "";
  const quantityLabel = getQuantityLabel(item);
  const quantityPlaceholder = item && !unitIsM2(item) ? "Área em m²" : "0,000";

  el.activeCategoryPanel.innerHTML = `
    <div class="category-title-row">
      <div>
        <p class="eyebrow dark">Categoria ativa</p>
        <h3>${escapeHtml(category.label)}</h3>
        <p>${escapeHtml(category.helper || "")}</p>
      </div>
      <span class="category-pill">${escapeHtml(status.text)}</span>
    </div>

    <div class="category-layout">
      <div class="category-main">
        ${selectedMarkup}

        <div class="entry-grid">
          <label class="field field-wide">
            <span>Buscar composição</span>
            <input class="item-search" type="search" value="${escapeHtml(searchValue)}" autocomplete="off" placeholder="Digite código ou palavra da descrição">
          </label>
          <label class="field">
            <span>${escapeHtml(quantityLabel)}</span>
            <input class="quantity-input" type="text" inputmode="decimal" autocomplete="off" value="${formatInputValue(quantity)}" placeholder="${escapeHtml(quantityPlaceholder)}">
          </label>
        </div>

        <div class="search-and-list">
          <div class="option-list"></div>
        </div>
      </div>

      <aside class="side-stack">
        ${conversionMarkup}
        ${metricsMarkup}
        ${renderCategoryNote(item, qtyData)}
      </aside>
    </div>
  `;

  const searchInput = el.activeCategoryPanel.querySelector(".item-search");
  const quantityInput = el.activeCategoryPanel.querySelector(".quantity-input");
  const conversionInput = el.activeCategoryPanel.querySelector(".conversion-input");
  const optionList = el.activeCategoryPanel.querySelector(".option-list");

  renderOptionList(categoryKey, optionList, searchValue);

  const renderSearchResults = debounce(() => {
    searchByCategory[categoryKey] = searchInput.value;
    renderOptionList(categoryKey, optionList, searchInput.value);
  });
  searchInput.addEventListener("input", renderSearchResults);

  quantityInput.addEventListener("input", () => {
    state.quantities[categoryKey] = readNumberInput(quantityInput);
    saveState();
    renderTabs();
    updateAll();
    updateActiveCategoryLightweight(categoryKey);
  });

  bindConversionInput(conversionInput, categoryKey);
}

function getQuantityLabel(item) {
  if (!item) return "Quantidade";
  if (unitIsM2(item)) return `Área/quantidade (${unitOf(item)})`;
  return "Área de referência (m²)";
}

function renderNoSelectionMarkup() {
  return `
    <div class="no-selection-card">
      <strong>Nenhuma composição selecionada</strong>
      <p>Escolha uma composição SINAPI nesta aba. A descrição completa aparecerá aqui antes do cálculo.</p>
    </div>
  `;
}

function renderSelectedMarkup(item, qtyData) {
  const complete = Number(item.is_complete) === 1;
  const unit = unitOf(item);
  const conversionText = qtyData.needsConversion
    ? `Como a unidade é ${unit}, informe área de referência e taxa ${unit}/m².`
    : "Como a unidade é m², informe diretamente a área ou quantidade da categoria.";

  return `
    <div class="selected-card">
      <div class="selected-card-header">
        <span class="selected-code">${escapeHtml(item.codigo_composicao)}</span>
        <div class="selected-tags">
          <span class="tag">${escapeHtml(unit)}</span>
          <span class="tag ${complete ? "" : "danger"}">${complete ? "dados completos" : "sem dados completos"}</span>
        </div>
      </div>
      <h4>${escapeHtml(item.descricao)}</h4>
      <p>${escapeHtml(conversionText)}</p>
    </div>
  `;
}

function renderConversionMarkup(item, qtyData) {
  const unit = unitOf(item);
  return `
    <div class="conversion-card">
      <h4>Conversão de unidade</h4>
      <p>Informe quantas unidades de <strong>${escapeHtml(unit)}</strong> existem por m² da área de referência.</p>
      <div class="conversion-grid">
        <label class="field">
          <span>Taxa de conversão (${escapeHtml(unit)}/m²)</span>
          <input class="conversion-input" type="text" inputmode="decimal" value="${escapeHtml(formatInputValue(qtyData.conversionRate))}" placeholder="Ex.: 0,12">
        </label>
        <div class="converted-box">
          <span>Quantidade convertida</span>
          <strong class="converted-quantity">${qtyData.hasConversion ? `${formatNumber(qtyData.effectiveQuantity, 3)} ${escapeHtml(unit)}` : "-"}</strong>
        </div>
      </div>
    </div>
  `;
}

function renderMetricsMarkup(category, item, qtyData) {
  const total = calculateSummary().total || 0;
  const complete = Number(item.is_complete) === 1;
  const hasValidEmission = complete && qtyData.baseQuantity > 0 && qtyData.hasConversion;
  const emission = hasValidEmission ? qtyData.effectiveQuantity * getFactor(item) : 0;
  const share = total > 0 && emission > 0 ? `${formatNumber((emission / total) * 100, 1)}%` : "-";
  const factor = getFactor(item);
  const unit = unitOf(item);

  return `
    <div class="metrics-card">
      <h4>Resumo da aba</h4>
      <div class="metric-grid">
        <div class="metric"><span>Unidade</span><strong>${escapeHtml(unit)}</strong></div>
        <div class="metric"><span>Fator</span><strong>${formatNumber(factor, 4)} kgCO₂e/${escapeHtml(unit)}</strong></div>
        <div class="metric"><span>Qtd. cálculo</span><strong>${qtyData.effectiveQuantity > 0 ? `${formatNumber(qtyData.effectiveQuantity, 3)} ${escapeHtml(unit)}` : "-"}</strong></div>
        <div class="metric"><span>Emissão</span><strong>${formatKg(emission, 1)}</strong></div>
        <div class="metric"><span>Participação</span><strong>${share}</strong></div>
        <div class="metric"><span>Status</span><strong>${escapeHtml(getCategoryStatus(category).text)}</strong></div>
      </div>
    </div>
  `;
}

function renderEmptyMetricsMarkup() {
  return `
    <div class="metrics-card">
      <h4>Resumo da aba</h4>
      <div class="note-box">Selecione uma composição para visualizar unidade, fator, quantidade convertida e emissão calculada.</div>
    </div>
  `;
}

function renderCategoryNote(item, qtyData) {
  if (!item) return `<div class="note-box category-note">Use a busca por código SINAPI ou palavra-chave. A lista contém apenas composições filtradas para esta categoria.</div>`;
  if (Number(item.is_complete) !== 1) return `<div class="note-box warning category-note">${escapeHtml(window.MISSING_DATA_MESSAGE || "s/dados escolha outra opção e informe a equipe de sustentabilidade")}</div>`;
  if (qtyData.needsConversion && !qtyData.hasConversion && qtyData.baseQuantity > 0) return `<div class="note-box warning category-note">Preencha a taxa de conversão para que esta categoria entre no total.</div>`;
  if (qtyData.needsConversion) return `<div class="note-box category-note">Cálculo usado: área de referência × taxa de conversão × fator de emissão.</div>`;
  return `<div class="note-box category-note">Cálculo usado: quantidade em m² × fator de emissão.</div>`;
}

function renderOptionList(categoryKey, container, searchValue = "") {
  const selectedCode = state.selected[categoryKey];
  const query = normalizeText(searchValue);
  const allItems = itemsByCategory[categoryKey] || [];
  const filtered = query
    ? allItems.filter((item) => normalizeText(`${item.codigo_composicao} ${item.descricao} ${item.unidade}`).includes(query))
    : allItems;

  const visibleItems = filtered.slice(0, MAX_VISIBLE_OPTIONS);
  const hiddenCount = Math.max(filtered.length - visibleItems.length, 0);

  container.innerHTML = `
    <div class="option-card none-option ${!selectedCode ? "selected" : ""}" role="button" tabindex="0" data-code="" aria-label="Não considerar esta categoria">
      <div class="option-main">
        <span class="option-code">Não considerar esta categoria</span>
        <span class="option-desc">Remove a categoria do cálculo sem apagar a quantidade ou taxa informada.</span>
      </div>
      <div class="option-badges"><span class="tag muted-tag">opcional</span></div>
    </div>
    ${visibleItems.map((item) => renderOptionCard(item, selectedCode)).join("")}
    ${hiddenCount > 0 ? `<div class="note-box">Mostrando ${MAX_VISIBLE_OPTIONS} de ${filtered.length} resultados. Refine a busca para ver opções mais específicas.</div>` : ""}
    ${!filtered.length ? `<div class="note-box warning">Nenhuma composição encontrada para esta busca.</div>` : ""}
  `;

  container.querySelectorAll(".option-card").forEach((card) => {
    const selectCard = () => {
      const code = card.dataset.code;
      if (!code) delete state.selected[categoryKey];
      else state.selected[categoryKey] = code;
      saveState();
      renderTabs();
      renderActiveCategory();
      updateAll();
    };
    card.addEventListener("click", selectCard);
    card.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        selectCard();
      }
    });
  });
}

function renderOptionCard(item, selectedCode) {
  const complete = Number(item.is_complete) === 1;
  const selected = String(selectedCode) === String(item.codigo_composicao);
  const unit = unitOf(item);
  return `
    <div class="option-card ${selected ? "selected" : ""}" role="button" tabindex="0" data-code="${escapeHtml(item.codigo_composicao)}" aria-label="Selecionar composição ${escapeHtml(item.codigo_composicao)}">
      <div class="option-main">
        <span class="option-code">${escapeHtml(item.codigo_composicao)}</span>
        <span class="option-desc">${escapeHtml(item.descricao)}</span>
      </div>
      <div class="option-badges">
        <span class="tag unit-tag">${escapeHtml(unit)}</span>
        <span class="tag ${complete ? "complete-tag" : "danger"}">${complete ? "completo" : "sem dados"}</span>
      </div>
    </div>
  `;
}

function updateActiveCategoryLightweight(categoryKey) {
  const category = categories.find((cat) => cat.category_key === categoryKey);
  if (!category) return;
  const item = findItem(categoryKey, state.selected[categoryKey]);
  const qtyData = getQuantityData(categoryKey, item);

  const sideStack = el.activeCategoryPanel.querySelector(".side-stack");
  const pill = el.activeCategoryPanel.querySelector(".category-pill");
  const quantityLabel = el.activeCategoryPanel.querySelector(".entry-grid .field:nth-child(2) span");

  if (pill) pill.textContent = getCategoryStatus(category).text;
  if (quantityLabel) quantityLabel.textContent = getQuantityLabel(item);
  if (!sideStack) return;

  const shouldHaveConversion = Boolean(item && qtyData.needsConversion);
  const hasConversionCard = Boolean(sideStack.querySelector(".conversion-card"));

  if (shouldHaveConversion !== hasConversionCard) {
    sideStack.innerHTML = `
      ${item && qtyData.needsConversion ? renderConversionMarkup(item, qtyData) : ""}
      ${item ? renderMetricsMarkup(category, item, qtyData) : renderEmptyMetricsMarkup()}
      ${renderCategoryNote(item, qtyData)}
    `;
    bindConversionInput(sideStack.querySelector(".conversion-input"), categoryKey);
    return;
  }

  const convertedQuantity = sideStack.querySelector(".converted-quantity");
  if (convertedQuantity && item) {
    convertedQuantity.textContent = qtyData.hasConversion ? `${formatNumber(qtyData.effectiveQuantity, 3)} ${unitOf(item)}` : "-";
  }

  const metricsCard = sideStack.querySelector(".metrics-card");
  if (metricsCard) {
    metricsCard.outerHTML = item ? renderMetricsMarkup(category, item, qtyData) : renderEmptyMetricsMarkup();
  }

  const note = sideStack.querySelector(".category-note");
  if (note) {
    note.outerHTML = renderCategoryNote(item, qtyData);
  }
}

function calculateSummary() {
  let total = 0;
  let missingWithQty = false;
  let conversionMissing = false;
  const rows = [];

  categories.forEach((category) => {
    const key = category.category_key;
    const item = findItem(key, state.selected[key]);
    if (!item) return;

    const qtyData = getQuantityData(key, item);
    if (qtyData.baseQuantity <= 0) return;

    const complete = Number(item.is_complete) === 1;
    if (!complete) {
      missingWithQty = true;
      rows.push({ categoria: category.label, codigo: item.codigo_composicao, descricao: item.descricao, unidade: unitOf(item), quantidade: qtyData.baseQuantity, emissao: 0, status: "sem dados" });
      return;
    }

    if (!qtyData.hasConversion) {
      conversionMissing = true;
      rows.push({ categoria: category.label, codigo: item.codigo_composicao, descricao: item.descricao, unidade: unitOf(item), quantidade: qtyData.baseQuantity, emissao: 0, status: "conversão pendente" });
      return;
    }

    const factor = getFactor(item);
    const emission = qtyData.effectiveQuantity * factor;
    total += emission;
    rows.push({ categoria: category.label, codigo: item.codigo_composicao, descricao: item.descricao, unidade: unitOf(item), quantidade: qtyData.effectiveQuantity, fator: factor, emissao: emission, status: "calculado" });
  });

  const major = rows.filter((row) => row.emissao > 0).reduce((acc, row) => (row.emissao > (acc?.emissao || 0) ? row : acc), null);
  const builtArea = Number(state.builtArea || 0);
  const areaRate = builtArea > 0 ? total / builtArea : null;
  const areaRateTon = areaRate === null ? null : areaRate / 1000;

  return {
    total,
    missingWithQty,
    conversionMissing,
    rows,
    builtArea,
    areaRate,
    areaRateTon,
    majorCategory: major ? major.categoria : "-",
    majorValue: major ? major.emissao : 0,
  };
}

function updateAll() {
  const summary = calculateSummary();
  updateSummaryPanel(summary);
  renderHistory();
  renderTabs();
  if (state.activeCategory === RESULTS_TAB_KEY) renderResultsTab(summary);
}

function updateSummaryPanel(summary) {
  el.totalEmission.textContent = formatKg(summary.total, 1);
  el.areaRate.textContent = summary.areaRate === null ? "-" : `${formatNumber(summary.areaRate, 2)} kgCO₂e/m²`;
  el.majorCategory.textContent = summary.majorCategory;
  el.majorCategoryValue.textContent = summary.majorValue > 0 ? formatKg(summary.majorValue, 1) : "sem valores calculados";
  el.missingDataAlert.classList.toggle("hidden", !summary.missingWithQty);
  el.conversionAlert.classList.toggle("hidden", !summary.conversionMissing);

  const previous = state.history.length ? state.history[state.history.length - 1] : null;
  if (!previous || !previous.total) {
    el.reductionIndicator.textContent = "sem histórico";
    el.reductionHelper.textContent = "registre uma simulação";
    return;
  }

  const variation = ((previous.total - summary.total) / previous.total) * 100;
  el.reductionIndicator.textContent = `${formatNumber(variation, 1)}%`;
  el.reductionHelper.textContent = variation >= 0 ? "redução vs. análise anterior" : "aumento vs. análise anterior";
}

function evaluateBenchmark(rateTon, benchmark) {
  if (rateTon === null || rateTon === undefined || Number.isNaN(rateTon)) {
    return { label: "informe a área construída", kind: "neutral" };
  }
  if (rateTon < benchmark.min) return { label: "abaixo da faixa", kind: "warning" };
  if (rateTon > benchmark.max) return { label: "acima da faixa", kind: "danger" };
  return { label: "dentro da faixa", kind: "ok" };
}

function renderResultsTab(existingSummary = null) {
  const summary = existingSummary || calculateSummary();
  const validRows = summary.rows.filter((row) => row.emissao > 0).sort((a, b) => b.emissao - a.emissao);
  const maxEmission = Math.max(...validRows.map((row) => row.emissao), 1);
  const rateTonText = summary.areaRateTon === null ? "-" : formatTon(summary.areaRateTon, 3);

  el.activeCategoryPanel.innerHTML = `
    <div class="results-tab-panel">
      <div class="category-title-row">
        <div>
          <p class="eyebrow dark">Síntese</p>
          <h3>Resultados e indicadores</h3>
          <p>Use esta aba para verificar o desempenho da simulação atual e comparar a taxa de carbono com faixas de referência.</p>
        </div>
        <span class="category-pill">${escapeHtml(SCENARIO_LABELS[state.scenario] || "médio")}</span>
      </div>

      <div class="results-hero">
        <div class="result-summary-card primary">
          <span>Total calculado</span>
          <strong>${formatKg(summary.total, 1)}</strong>
          <small>${summary.rows.length} categoria(s) com entrada preenchida</small>
        </div>
        <div class="result-summary-card">
          <span>Taxa de carbono por área construída</span>
          <strong>${rateTonText}</strong>
          <small>${summary.areaRate === null ? "preencha a área construída total para avaliar as faixas" : `${formatNumber(summary.areaRate, 2)} kgCO₂e/m²`}</small>
        </div>
      </div>

      <div class="benchmark-grid">
        ${BENCHMARKS.map((benchmark) => renderBenchmarkCard(summary.areaRateTon, benchmark)).join("")}
      </div>

      <div class="breakdown-card">
        <h3>Contribuição por categoria</h3>
        ${validRows.length ? `
          <div class="breakdown-grid">
            ${validRows.map((row) => renderBreakdownRow(row, maxEmission)).join("")}
          </div>
        ` : `<div class="note-box">Nenhuma categoria válida foi calculada ainda. Preencha as abas de categoria para formar o resultado.</div>`}
      </div>

      <div class="references-box">
        Referências de comparação incluídas conforme informado: SindusCon/SP (2024), com faixa de 0,10 a 0,52 tCO₂e/m², e estudos de Caldas et al. (2017), Belizário (2022) e Melo et al. (2023), com faixa de 0,27 a 0,39 tCO₂e/m².
      </div>
    </div>
  `;
}

function renderBenchmarkCard(rateTon, benchmark) {
  const evaluation = evaluateBenchmark(rateTon, benchmark);
  return `
    <div class="benchmark-card ${evaluation.kind}">
      <span>Faixa de referência</span>
      <h4>${escapeHtml(benchmark.title)}</h4>
      <p>${escapeHtml(benchmark.note)}</p>
      <strong>${escapeHtml(benchmark.label)}</strong>
      <div class="benchmark-status">${escapeHtml(evaluation.label)}</div>
    </div>
  `;
}

function renderBreakdownRow(row, maxEmission) {
  const width = Math.max((row.emissao / maxEmission) * 100, 2);
  return `
    <div class="breakdown-row">
      <div class="breakdown-label">
        ${escapeHtml(row.categoria)}
        <span class="breakdown-desc">${escapeHtml(row.codigo)} • ${escapeHtml(row.unidade)} • ${escapeHtml(row.descricao || "")}</span>
      </div>
      <div class="breakdown-track"><div class="breakdown-fill" style="width:${width}%"></div></div>
      <div class="breakdown-value">${formatKg(row.emissao, 1)}</div>
    </div>
  `;
}

function renderHistory() {
  const history = state.history || [];
  el.historyEmpty.classList.toggle("hidden", history.length > 0);
  el.historyContent.classList.toggle("hidden", history.length === 0);
  if (!history.length) return;

  renderHistoryChart(history);
  renderHistoryHighlights(history);
  el.historyRows.innerHTML = history.slice().reverse().map((entry) => `
    <div class="history-entry">
      <strong>${escapeHtml(entry.nome)}</strong>
      <small>${escapeHtml(entry.cenarioLabel || SCENARIO_LABELS[entry.cenario] || "-")} • ${formatKg(entry.total, 1)} • ${entry.areaRate === null || entry.areaRate === undefined ? "-" : `${formatNumber(entry.areaRate, 2)} kgCO₂e/m²`}</small>
      <small>Maior categoria: ${escapeHtml(entry.majorCategory || "-")} • ${escapeHtml(entry.createdAt || "-")}</small>
    </div>
  `).join("");
}

function renderHistoryChart(history) {
  const totals = history.map((entry) => Number(entry.total) || 0);
  const max = Math.max(...totals, 1);
  const min = Math.min(...totals);

  el.historyChart.innerHTML = history.map((entry) => {
    const total = Number(entry.total) || 0;
    const width = Math.max((total / max) * 100, 2);
    const isBest = history.length > 1 && total === min;
    const isWorst = history.length > 1 && total === max;
    const badge = isBest ? "melhor" : isWorst ? "pior" : "";
    return `
      <div class="bar-row">
        <div class="bar-label" title="${escapeHtml(entry.nome)}">${escapeHtml(entry.nome)} ${badge ? `• ${badge}` : ""}</div>
        <div class="bar-track"><div class="bar-fill ${isBest ? "best" : isWorst ? "worst" : ""}" style="width:${width}%"></div></div>
        <div class="bar-value">${formatKg(total, 0)}</div>
      </div>
    `;
  }).join("");
}

function renderHistoryHighlights(history) {
  const best = history.reduce((acc, entry) => ((entry.total || 0) < (acc.total || Infinity) ? entry : acc), history[0]);
  const worst = history.reduce((acc, entry) => ((entry.total || 0) > (acc.total || -Infinity) ? entry : acc), history[0]);
  const average = history.reduce((sum, entry) => sum + (Number(entry.total) || 0), 0) / history.length;

  el.historyHighlights.innerHTML = `
    <div><span>Melhor</span><strong>${escapeHtml(best.nome)}</strong><small>${formatKg(best.total, 1)}</small></div>
    <div><span>Pior</span><strong>${escapeHtml(worst.nome)}</strong><small>${formatKg(worst.total, 1)}</small></div>
    <div><span>Média</span><strong>${formatKg(average, 1)}</strong><small>${history.length} simulações</small></div>
  `;
}

async function bootstrap() {
  el.scenarioName.value = state.scenarioName || `Simulação ${state.counter || 1}`;
  el.builtArea.value = state.builtArea || "";
  el.showIncomplete.checked = state.showIncomplete !== false;
  setScenarioButtons();
  bindGlobalEvents();

  try {
    categories = await fetchJson("/api/categories");
    if (!categories.length) {
      el.activeCategoryPanel.innerHTML = `<div class="loading-card">Nenhuma categoria cadastrada no banco local.</div>`;
      return;
    }

    if (!state.activeCategory || (!categories.some((cat) => cat.category_key === state.activeCategory) && state.activeCategory !== RESULTS_TAB_KEY)) {
      state.activeCategory = categories[0].category_key;
      saveState();
    }

    await loadAllItems();
    cleanupInvalidSelections();
    renderTabs();
    renderActiveCategory();
    updateAll();
  } catch (err) {
    el.activeCategoryPanel.innerHTML = `<div class="status-alert"><strong>Erro ao carregar a calculadora.</strong><p>${escapeHtml(err.message)}</p></div>`;
  }
}

bootstrap();
