:root {
  --blue-900: #062f52;
  --blue-800: #0a426f;
  --blue-600: #0067ff;
  --cyan-500: #2aa7d7;
  --mint-500: #179b75;
  --mint-100: #e4f6ef;
  --coral-500: #e85c46;
  --amber-500: #b77a00;
  --paper: #ffffff;
  --surface: #f4f7fb;
  --surface-2: #e9f0f7;
  --line: #d6e0ea;
  --line-strong: #b6c6d6;
  --ink: #102033;
  --text: #28374a;
  --muted: #66758a;
  --shadow: 0 16px 36px rgba(7, 28, 48, 0.12);
  --radius: 8px;
  font-family: Aptos, Roboto, Arial, sans-serif;
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  min-height: 100vh;
  color: var(--ink);
  background:
    linear-gradient(rgba(255,255,255,0.74), rgba(255,255,255,0.74)),
    linear-gradient(135deg, transparent 0 49%, rgba(6,47,82,0.08) 49% 51%, transparent 51%),
    linear-gradient(45deg, transparent 0 49%, rgba(23,155,117,0.07) 49% 51%, transparent 51%),
    #eef4f8;
  background-size: auto, 96px 96px, 96px 96px, auto;
}

button,
input { font: inherit; }
button { cursor: pointer; }
h1, h2, h3, h4, p { margin-top: 0; }

.app-background {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(6,47,82,0.06) 1px, transparent 1px),
    linear-gradient(0deg, rgba(6,47,82,0.05) 1px, transparent 1px);
  background-size: 64px 64px;
}

.dashboard-shell {
  display: grid;
  grid-template-columns: 356px minmax(0, 1fr);
  gap: 18px;
  width: min(100% - 24px, 1760px);
  min-height: calc(100vh - 24px);
  margin: 12px auto;
}

.sidebar {
  position: sticky;
  top: 12px;
  display: grid;
  align-content: start;
  gap: 12px;
  height: calc(100vh - 24px);
  overflow: hidden;
  padding: 14px;
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: var(--radius);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.08), transparent 34%),
    var(--blue-900);
  box-shadow: var(--shadow);
}

.dashboard-main {
  display: grid;
  align-content: start;
  gap: 12px;
  min-width: 0;
}

.brand-panel {
  display: grid;
  grid-template-columns: 48px minmax(0, 1fr);
  gap: 12px;
  align-items: center;
  min-height: 74px;
  color: #fff;
}

.brand-mark {
  position: relative;
  width: 46px;
  height: 46px;
}
.brand-mark span {
  position: absolute;
  inset: 9px;
  border: 2px solid rgba(255,255,255,0.78);
  border-radius: 5px;
  transform: rotate(45deg);
}
.brand-mark span:nth-child(2) { transform: translateX(8px) rotate(45deg); }
.brand-mark span:nth-child(3) { transform: translateX(-8px) rotate(45deg); }
.brand-mark span:nth-child(4) { inset: 18px; background: var(--cyan-500); }

.eyebrow {
  margin: 0 0 4px;
  color: rgba(255,255,255,0.74);
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  line-height: 1.2;
  text-transform: uppercase;
}
.eyebrow.dark { color: var(--blue-600); }

h1 {
  margin: 0;
  font-size: 1.42rem;
  line-height: 1.05;
  letter-spacing: 0;
}

.hero-version {
  display: inline-flex;
  margin-top: 7px;
  padding: 3px 7px;
  border-radius: 999px;
  color: #d9efff;
  background: rgba(255,255,255,0.12);
  font-size: 0.72rem;
  font-weight: 900;
}

.topbar,
.panel-card,
.category-panel,
.loading-card,
.kpi,
.status-alert {
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: rgba(255,255,255,0.95);
  box-shadow: 0 8px 20px rgba(7, 28, 48, 0.07);
}

.topbar {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
  min-height: 74px;
  padding: 14px 18px;
}
.topbar h2 {
  margin: 0;
  color: var(--blue-900);
  font-size: clamp(1.35rem, 2.2vw, 2.35rem);
  line-height: 1.05;
  letter-spacing: 0;
}
.topbar-actions span {
  display: inline-flex;
  padding: 8px 11px;
  border-radius: 999px;
  color: var(--blue-900);
  background: var(--surface-2);
  font-size: 0.86rem;
  font-weight: 900;
}

.panel-card { padding: 12px; }

.controls-panel {
  color: #f7fbff;
  border-color: rgba(255,255,255,0.18);
  background: rgba(255,255,255,0.08);
  box-shadow: none;
}

.panel-heading {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 10px;
}
.panel-heading h2 {
  margin: 0;
  color: inherit;
  font-size: 1rem;
  line-height: 1.15;
}
.history-panel .panel-heading h2 { color: var(--blue-900); }

.form-grid {
  display: grid;
  gap: 8px;
}
.field {
  display: grid;
  gap: 5px;
}
.field span,
.input-label {
  color: inherit;
  font-size: 0.75rem;
  font-weight: 900;
}

input[type="text"],
input[type="number"],
input[type="search"] {
  width: 100%;
  min-height: 36px;
  border: 1px solid rgba(255,255,255,0.22);
  border-radius: 6px;
  padding: 7px 9px;
  color: var(--ink);
  background: #fff;
  outline: none;
}
.dashboard-main input[type="text"],
.dashboard-main input[type="number"],
.dashboard-main input[type="search"] {
  border-color: var(--line-strong);
  background: #fafdff;
}
input:focus {
  border-color: var(--blue-600);
  box-shadow: 0 0 0 3px rgba(0,103,255,0.12);
}

.scenario-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
  margin-top: 10px;
  padding: 3px;
  border-radius: 7px;
  background: rgba(255,255,255,0.12);
}
.scenario-btn {
  min-height: 32px;
  border: 0;
  border-radius: 5px;
  color: #d9efff;
  background: transparent;
  font-size: 0.82rem;
  font-weight: 900;
}
.scenario-btn.active {
  color: var(--blue-900);
  background: #fff;
}

.control-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
}
.checkbox-line {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #e7f3ff;
  font-size: 0.76rem;
  font-weight: 800;
}
.checkbox-line input {
  width: 16px;
  height: 16px;
  accent-color: var(--mint-500);
}

.primary-button,
.text-button {
  min-height: 32px;
  border: 0;
  border-radius: 6px;
  font-weight: 900;
}
.primary-button {
  padding: 0 12px;
  color: #fff;
  background: var(--mint-500);
}
.text-button {
  padding: 0 9px;
  color: var(--blue-900);
  background: #e8f2fb;
  font-size: 0.8rem;
}
.text-button.danger {
  color: #fff;
  background: rgba(232,92,70,0.94);
}

.category-tabs {
  display: grid;
  gap: 6px;
  min-height: 0;
  overflow: auto;
  padding-right: 3px;
  scrollbar-width: thin;
}
.tab-button {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 3px 8px;
  align-items: center;
  width: 100%;
  min-height: 58px;
  padding: 9px;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 7px;
  color: #d8e8f6;
  background: rgba(255,255,255,0.08);
  text-align: left;
  transition: background 0.16s ease, transform 0.16s ease, border-color 0.16s ease;
}
.tab-button:hover {
  transform: translateX(1px);
  background: rgba(255,255,255,0.13);
}
.tab-button.active {
  color: var(--blue-900);
  border-color: transparent;
  background: #fff;
}
.tab-index {
  grid-column: 1 / -1;
  color: currentColor;
  opacity: 0.64;
  font-size: 0.58rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.tab-label {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 0.86rem;
  font-weight: 900;
}
.tab-status {
  justify-self: end;
  padding: 3px 7px;
  border-radius: 999px;
  color: var(--muted);
  background: rgba(255,255,255,0.72);
  font-size: 0.65rem;
  font-weight: 900;
  white-space: nowrap;
}
.tab-button.ready .tab-status { color: #0d684e; background: #dff6ee; }
.tab-button.warning .tab-status { color: #9b321d; background: #ffe6df; }
.tab-button.pending .tab-status { color: #765000; background: #fff0c7; }
.tab-button.results-tab {
  margin-top: 4px;
  background: rgba(23,155,117,0.22);
}
.tab-button.results-tab.active { background: #fff; }

.kpi-grid {
  display: grid;
  grid-template-columns: minmax(260px, 1.2fr) repeat(3, minmax(160px, 1fr));
  gap: 12px;
}
.kpi {
  min-width: 0;
  min-height: 112px;
  padding: 14px;
  display: grid;
  align-content: end;
}
.kpi.main-kpi {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(135deg, var(--blue-900), var(--blue-800));
}
.kpi span,
.metric span,
.history-highlights span,
.benchmark-card span,
.result-summary-card span {
  display: block;
  margin-bottom: 5px;
  color: var(--muted);
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.kpi.main-kpi span,
.kpi.main-kpi small { color: rgba(255,255,255,0.74); }
.kpi strong {
  display: block;
  overflow-wrap: anywhere;
  color: var(--blue-900);
  font-size: clamp(1rem, 1.28vw, 1.3rem);
  line-height: 1.14;
}
.kpi.main-kpi strong {
  color: #fff;
  font-size: clamp(1.45rem, 2.3vw, 2.45rem);
}
.kpi small {
  display: block;
  margin-top: 5px;
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.status-alert {
  padding: 10px 12px;
  color: #82301f;
  border-color: #ffd2c6;
  background: #fff0ec;
}
.status-alert.blue {
  color: var(--blue-900);
  border-color: #c6def2;
  background: #eef7ff;
}
.status-alert p {
  margin: 3px 0 0;
  line-height: 1.35;
}
.hidden { display: none !important; }

.dashboard-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 340px;
  gap: 12px;
  align-items: start;
}
.category-panel {
  min-width: 0;
  padding: 14px;
}
.loading-card {
  padding: 22px;
  color: var(--muted);
  font-weight: 900;
}

.category-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14px;
  margin-bottom: 12px;
}
.category-title-row h3 {
  margin: 0;
  color: var(--blue-900);
  font-size: 1.35rem;
  line-height: 1.12;
}
.category-title-row p {
  max-width: 820px;
  margin: 5px 0 0;
  color: var(--muted);
  font-size: 0.88rem;
  line-height: 1.35;
}
.category-pill {
  flex: 0 0 auto;
  padding: 6px 9px;
  border-radius: 999px;
  color: var(--blue-900);
  background: var(--surface-2);
  font-size: 0.76rem;
  font-weight: 900;
}

.category-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 300px;
  gap: 12px;
  align-items: start;
}
.category-main,
.side-stack { min-width: 0; }
.side-stack {
  display: grid;
  gap: 10px;
}

.selected-card,
.no-selection-card,
.conversion-card,
.metrics-card,
.benchmark-card,
.breakdown-card,
.result-summary-card,
.option-card {
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #fff;
}
.selected-card,
.no-selection-card {
  padding: 12px;
  margin-bottom: 10px;
}
.no-selection-card {
  color: var(--muted);
  border-style: dashed;
  background: #fbfdff;
}
.selected-card-header {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: flex-start;
  margin-bottom: 7px;
}
.selected-code {
  display: inline-flex;
  padding: 4px 7px;
  border-radius: 999px;
  color: var(--blue-900);
  background: #e8f2fb;
  font-size: 0.76rem;
  font-weight: 900;
}
.selected-tags,
.option-badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 5px;
}
.selected-card h4 {
  margin: 0;
  color: var(--blue-900);
  font-size: 0.96rem;
  line-height: 1.28;
}
.selected-card p,
.no-selection-card p,
.conversion-card p {
  margin: 6px 0 0;
  color: var(--muted);
  font-size: 0.84rem;
  line-height: 1.35;
}
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 7px;
  border-radius: 999px;
  color: var(--blue-900);
  background: #e5f1fa;
  font-size: 0.66rem;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}
.tag.danger { color: #8f2f1b; background: #ffe6df; }
.complete-tag { color: #0d684e; background: #dff6ee; }
.muted-tag { color: var(--muted); background: var(--surface-2); }

.entry-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 190px;
  gap: 10px;
  align-items: end;
  margin-bottom: 10px;
}
.search-and-list { min-width: 0; }
.option-list {
  display: grid;
  gap: 7px;
  max-height: min(52vh, 520px);
  overflow: auto;
  padding-right: 4px;
}
.option-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 8px;
  align-items: start;
  width: 100%;
  min-height: 62px;
  padding: 10px;
  user-select: none;
  transition: border-color 0.16s ease, background 0.16s ease, transform 0.16s ease;
}
.option-card:hover {
  transform: translateY(-1px);
  border-color: var(--blue-600);
  background: #fbfdff;
}
.option-card.selected {
  border-color: var(--mint-500);
  background: var(--mint-100);
}
.option-main {
  display: grid;
  gap: 5px;
  min-width: 0;
}
.option-code {
  color: var(--blue-900);
  font-size: 0.78rem;
  font-weight: 900;
}
.option-desc {
  color: var(--text);
  font-size: 0.78rem;
  font-weight: 650;
  line-height: 1.32;
}
.option-badges {
  max-width: 156px;
}
.option-card:focus-visible {
  outline: 3px solid rgba(0,103,255,0.18);
  outline-offset: 2px;
}

.conversion-card,
.metrics-card {
  padding: 12px;
}
.conversion-card h4,
.metrics-card h4,
.breakdown-card h3 {
  margin: 0 0 8px;
  color: var(--blue-900);
  font-size: 0.98rem;
}
.conversion-grid {
  display: grid;
  gap: 8px;
}
.converted-box,
.metric {
  min-width: 0;
  padding: 9px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: #fafdff;
}
.converted-box span {
  display: block;
  margin-bottom: 4px;
  color: var(--muted);
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.converted-box strong,
.metric strong {
  color: var(--blue-900);
  overflow-wrap: anywhere;
}
.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.note-box {
  padding: 10px;
  border-radius: var(--radius);
  color: var(--blue-900);
  background: #edf6fb;
  font-size: 0.84rem;
  font-weight: 800;
  line-height: 1.35;
}
.note-box.warning {
  color: #82301f;
  background: #fff0ec;
}

.history-panel {
  position: sticky;
  top: 12px;
}
.empty-mini {
  padding: 14px;
  color: var(--muted);
  border: 1px dashed var(--line-strong);
  border-radius: var(--radius);
  background: #fbfdff;
  font-size: 0.9rem;
  font-weight: 800;
}
.mini-chart {
  display: grid;
  gap: 8px;
}
.bar-row {
  display: grid;
  grid-template-columns: minmax(70px, 0.9fr) minmax(70px, 1fr) auto;
  gap: 7px;
  align-items: center;
  font-size: 0.74rem;
}
.bar-label {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--ink);
  font-weight: 900;
}
.bar-track {
  height: 8px;
  overflow: hidden;
  border-radius: 999px;
  background: #dce8f3;
}
.bar-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--blue-600);
}
.bar-fill.best { background: var(--mint-500); }
.bar-fill.worst { background: var(--coral-500); }
.bar-value {
  color: var(--muted);
  font-weight: 900;
  white-space: nowrap;
}
.history-highlights {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 7px;
  margin-top: 10px;
}
.history-highlights div {
  min-width: 0;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: #fafdff;
}
.history-highlights strong {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--blue-900);
  font-size: 0.78rem;
}
.history-highlights small {
  display: block;
  margin-top: 3px;
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 800;
}
.history-details {
  margin-top: 9px;
}
.history-details summary {
  color: var(--blue-600);
  font-size: 0.84rem;
  font-weight: 900;
  cursor: pointer;
}
.history-list {
  display: grid;
  gap: 7px;
  max-height: 180px;
  overflow: auto;
  margin-top: 8px;
}
.history-entry {
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: #fff;
}
.history-entry strong,
.history-entry small {
  display: block;
}
.history-entry small {
  color: var(--muted);
  font-size: 0.74rem;
  font-weight: 800;
}

.results-tab-panel {
  display: grid;
  gap: 12px;
}
.results-hero,
.benchmark-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}
.result-summary-card,
.benchmark-card,
.breakdown-card {
  padding: 12px;
}
.result-summary-card.primary {
  color: #fff;
  border-color: transparent;
  background: linear-gradient(135deg, var(--blue-900), var(--blue-800));
}
.result-summary-card strong {
  display: block;
  color: var(--blue-900);
  font-size: clamp(1.35rem, 2vw, 2rem);
  line-height: 1.08;
}
.result-summary-card.primary strong,
.result-summary-card.primary span,
.result-summary-card.primary small { color: #fff; }
.result-summary-card small {
  display: block;
  margin-top: 5px;
  color: var(--muted);
  font-weight: 800;
}
.benchmark-card {
  border-left: 4px solid var(--line-strong);
}
.benchmark-card.ok { border-left-color: var(--mint-500); background: #f2fbf7; }
.benchmark-card.warning { border-left-color: var(--amber-500); background: #fff9ec; }
.benchmark-card.danger { border-left-color: var(--coral-500); background: #fff0ec; }
.benchmark-card.neutral { border-left-color: var(--blue-600); background: #f5fbff; }
.benchmark-card h4 {
  margin: 0 0 6px;
  color: var(--blue-900);
  font-size: 0.98rem;
}
.benchmark-card p,
.references-box {
  color: var(--muted);
  font-size: 0.84rem;
  line-height: 1.38;
}
.benchmark-card strong {
  display: block;
  margin-top: 8px;
  color: var(--blue-900);
}
.benchmark-status {
  display: inline-flex;
  margin-top: 8px;
  padding: 4px 7px;
  border-radius: 999px;
  color: var(--blue-900);
  background: rgba(6,47,82,0.08);
  font-size: 0.76rem;
  font-weight: 900;
}
.breakdown-grid {
  display: grid;
  gap: 7px;
}
.breakdown-row {
  display: grid;
  grid-template-columns: minmax(160px, 0.9fr) minmax(160px, 1.1fr) auto;
  gap: 9px;
  align-items: center;
  padding: 9px;
  border: 1px solid var(--line);
  border-radius: 7px;
  background: #fafdff;
}
.breakdown-label {
  min-width: 0;
  color: var(--blue-900);
  font-weight: 900;
}
.breakdown-desc {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: var(--muted);
  font-size: 0.76rem;
  font-weight: 800;
}
.breakdown-track {
  height: 8px;
  overflow: hidden;
  border-radius: 999px;
  background: #dce8f3;
}
.breakdown-fill {
  height: 100%;
  border-radius: inherit;
  background: var(--mint-500);
}
.breakdown-value {
  color: var(--blue-900);
  font-weight: 900;
  white-space: nowrap;
}

@media (max-width: 1280px) {
  .dashboard-shell {
    grid-template-columns: 310px minmax(0, 1fr);
  }
  .kpi-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .dashboard-grid {
    grid-template-columns: 1fr;
  }
  .history-panel {
    position: static;
  }
}

@media (max-width: 980px) {
  .dashboard-shell {
    grid-template-columns: 1fr;
  }
  .sidebar {
    position: static;
    height: auto;
    max-height: none;
  }
  .category-tabs {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-height: 320px;
  }
  .category-layout,
  .results-hero,
  .benchmark-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 680px) {
  .dashboard-shell {
    width: min(100% - 14px, 1760px);
    margin: 7px auto;
  }
  .topbar,
  .category-title-row,
  .selected-card-header {
    display: grid;
  }
  .kpi-grid,
  .entry-grid,
  .category-tabs,
  .metric-grid,
  .breakdown-row {
    grid-template-columns: 1fr;
  }
  .option-card {
    grid-template-columns: 1fr;
  }
  .option-badges,
  .selected-tags {
    justify-content: flex-start;
    max-width: none;
  }
}
